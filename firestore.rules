rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Messages collection: allow public writes (for contact forms), but only authenticated reads
    match /messages/{messageId} {
      allow create: if true; // Allow anyone to create messages (public contact forms)
      allow read, update, delete: if request.auth != null; // Only authenticated users can read/update/delete
    }
    
    // Subscribers collection: allow public writes (for newsletter signup), but only authenticated reads
    match /subscribers/{subscriberId} {
      allow create: if true; // Allow anyone to create subscribers (public newsletter forms)
      allow read, update, delete: if request.auth != null; // Only authenticated users can read/update/delete
    }
    
    // All other collections: require authentication
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
